#include <stdio.h>
#include <stdlib.h>

int main() {
    int n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);
    int *m_ptr = (int*) malloc(n * sizeof(int));
    printf("Enter elements (malloc):\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &m_ptr[i]);
    }
   printf("Elements using malloc:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", m_ptr[i]);
    }

  
    int *c_ptr = (int*) calloc(n, sizeof(int));

    printf("\nElements using calloc (default initialized to 0) :\n");
    for(i = 0; i < n; i++) {
        printf("%d ", c_ptr[i]);
    }

    free(m_ptr);
    free(c_ptr);

    return 0;
}
