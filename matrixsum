#include <stdio.h>
int main(){
int a[10][10],b[10][10],sum[10][10];
int i,j,rows,cols;
	printf("Enter no.of rows:");
	scanf("%d",&rows);
	printf("Enter no.of columns:");
	scanf("%d",&cols);
	printf("\nEnter the elements of first matrix:\n");
	for(i=0;i<rows;i++)
	{
	for(j=0;j<cols;j++)
	{
	scanf("%d",&a[i][j]);
	}}
	printf("Enter the elements of second matrix:\n");
	for(i=0;i<rows;i++)
	{
	for(j=0;j<cols;j++)
	{
	scanf("%d",&b[i][j]);
	}}
	for(i=0;i<rows;i++)
	{
	for(j=0;j<cols;j++)
	{
	sum[i][j]=a[i][j]+b[i][j];
	}}
	printf("sum of matrices:\n");
	for(i=0;i<rows;i++)
	{
	for(j=0;j<cols;j++)
	{
	printf(" %d ",sum[i][j]);
	}
