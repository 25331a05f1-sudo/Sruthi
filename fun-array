#include <stdio.h>
void displayArray(int arr[], int size);
int main()
{

int numbers[5] = {10, 20, 30, 40, 50};
displayArray(numbers, 5);
return 0;
}

void displayArray(int arr[], int size) 
{
int i;
printf("Array elements are:\n");
for (i = 0; i &lt; size; i++)
{
printf("%d\n", arr[i]);
}
printf("\n");
}


