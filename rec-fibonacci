#include &lt;stdio.h&gt;
int fibonacci(int n); 
int main()
{
int n, i;
printf(&quot;Enter number of terms: &quot;);
scanf(&quot;%d&quot;, &amp;n);
printf(&quot;Fibonacci Series: &quot;);
for (i = 0; i &lt; n; i++) {
printf(&quot;%d &quot;, fibonacci(i)); 
}
return 0;
}

int fibonacci(int n) {
if (n == 0)
return 0;
else if (n == 1)

return 1;

else
return fibonacci(n - 1) + fibonacci(n - 2);
}
