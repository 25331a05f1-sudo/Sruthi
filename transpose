#include <stdio.h>
int main(){
int i,j,rows,cols;
int a[10][10],tr[10][10];
	printf("Enter no.of rows and columns:");
	scanf("%d%d",&rows,&cols);
	printf("Enter elements of matrix:\n");
	for(i=0;i<rows;i++)
	{
	for(j=0;j<cols;j++)
	{
	scanf("%d",&a[i][j]);
	}}
	for(i=0;i<rows;i++)
	{
	for(j=0;j<cols;j++)
          tr[j][i]=a[i][j];
	}}
	printf("transpose of matrix:\n");
	for(i=0;i<cols;i++)
	{
	for(j=0;j<rows;j++)
	{
	printf("%d",tr[i][j]);
	}
